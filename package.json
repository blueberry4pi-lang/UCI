{
  "name": "uci-cycling-data-app",
  "version": "1.0.0",
  "description": "A Node.js application for retrieving and displaying UCI cycling data including races, rankings, and countdown timers",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest test/",
    "docker:build": "docker build -t uci-cycling-app .",
    "docker:run": "docker run -p 3000:3000 uci-cycling-app",
    "docker:compose": "docker-compose up -d"
  },
  "keywords": [
    "uci",
    "cycling",
    "racing",
    "data",
    "api",
    "express",
    "nodejs"
  ],
  "author": "UCI Cycling Data Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.4.0",
    "node-cron": "^3.0.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uci-cycling-data-app.git"
  },
  "bugs": {
    "url": "https://github.com/uci-cycling-data-app/issues"
  },
  "homepage": "https://github.com/uci-cycling-data-app#readme"
}